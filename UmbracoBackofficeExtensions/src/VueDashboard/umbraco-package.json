{
  "$schema": "../../src/Semler.BrandSites.Web/umbraco-package-schema.json",
  "id": "semler-vue-dashboard",
  "name": "Semler Vue Dashboard",
  "version": "1.0.0",
  "allowTelemetry": false,
  "extensions": [
    {
      "type": "dashboard",
      "alias": "Semler.Dashboard.BrandOverview",
      "name": "Brand Overview",
      "element": "/App_Plugins/BackofficeExtensions/vue-dashboard.js",
      "elementName": "semler-brand-dashboard",
      "weight": 200,
      "meta": {
        "label": "Brand Overblik",
        "pathname": "brand-overview"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Content"
        }
      ]
    }
  ]
}