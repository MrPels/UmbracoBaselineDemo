@model StageBlock

<section class="stage-block">
    @if (Model.Image != null)
    {
        <img src="@Model.Image.MediaUrl()" alt="@Model.Image.Name" />
    }
    @if (!string.IsNullOrEmpty(Model.Headline))
    {
        <h1>@Model.Headline</h1>
    }
    @if (!string.IsNullOrEmpty(Model.Text))
    {
        <p>@Model.Text</p>
    }
</section>